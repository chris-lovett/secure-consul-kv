# Sentinel Policy: KV Entry Size Limit
# Reference implementation for embedding in ACL policy key_prefix sentinel stanzas.
#
# HOW IT WORKS
# ------------
# Consul evaluates this code on every KV write that falls under a key_prefix stanza
# containing a sentinel { code = ... } block. Three variables are injected automatically:
#
#   key   (string) — the full KV key path being written (e.g. "AIT-001/config/db-host")
#   value (string) — the raw string value being stored
#   flags (int)    — the optional integer flags field on the KV entry
#
# The enforcement level (advisory / soft-mandatory / hard-mandatory) is declared in the
# ACL stanza, not in this code. Example ACL stanza:
#
#   key_prefix "AIT-001/" {
#     policy = "write"
#     sentinel {
#       code          = <<EOF
#         <paste this file's rule definitions here>
#       EOF
#       enforcementlevel = "soft-mandatory"
#     }
#   }
#
#
  }
}
enforcementlevel = "soft-mandatory"
